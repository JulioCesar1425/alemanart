---
import data from '../data/testimonios.json';
---

<section id="opiniones" class="brand-wash scroll-mt-20 py-16 md:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
    <h2 class="section-title text-3xl sm:text-4xl">Lo que dicen nuestros clientes</h2>

    <div class="swiper mt-10" id="swiper-testimonios">
      <div class="swiper-wrapper">
        {
          data.testimonios.map((t) => (
            <div class="swiper-slide px-2 pb-12">
              <figure class="mx-auto max-w-2xl rounded-2xl border border-tinta/10 bg-white p-6 shadow-sm sm:p-8">
                <svg
                  class="mx-auto h-8 w-8 text-dorado"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M9.5 8C7 8 5 10 5 12.5S7 17 9.5 17c.3 0 .6 0 .9-.1-.7 1.4-1.9 2.4-3.4 2.9l.6 1.7c3.5-1 5.9-4.2 5.9-8V12c0-2.2-1.8-4-4-4zm9 0c-2.5 0-4.5 2-4.5 4.5S16 17 18.5 17c.3 0 .6 0 .9-.1-.7 1.4-1.9 2.4-3.4 2.9l.6 1.7c3.5-1 5.9-4.2 5.9-8V12c0-2.2-1.8-4-4-4z" />
                </svg>
                <blockquote class="mt-4 text-base leading-relaxed text-tinta sm:text-lg">
                  {t.texto}
                </blockquote>
                <figcaption class="mt-5 text-sm font-medium uppercase tracking-wider text-azul">
                  {t.autor}
                </figcaption>
              </figure>
            </div>
          ))
        }
      </div>
      <div class="swiper-pagination"></div>
    </div>

    <div class="mt-1 flex items-center justify-center gap-3">
      <button
        type="button"
        id="testi-prev"
        aria-label="Opinión anterior"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-tinta/15 text-tinta-suave transition-colors hover:border-coral hover:text-coral"
      >
        <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M10 3 5 8l5 5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
      <button
        type="button"
        id="testi-next"
        aria-label="Siguiente opinión"
        class="flex h-10 w-10 items-center justify-center rounded-full border border-tinta/15 text-tinta-suave transition-colors hover:border-coral hover:text-coral"
      >
        <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="m6 3 5 5-5 5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination, Keyboard, Navigation, A11y } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';
  import 'swiper/css/navigation';

  const reducido = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  new Swiper('#swiper-testimonios', {
    modules: [Autoplay, Pagination, Keyboard, Navigation, A11y],
    effect: 'slide',
    speed: 650,
    loop: true,
    grabCursor: true,
    spaceBetween: 24,
    // Se reanuda tras interactuar y solo pausa mientras el cursor está encima.
    autoplay: reducido
      ? false
      : { delay: 5500, disableOnInteraction: false, pauseOnMouseEnter: true },
    keyboard: { enabled: true },
    pagination: { el: '.swiper-pagination', clickable: true },
    navigation: { prevEl: '#testi-prev', nextEl: '#testi-next' },
    a11y: {
      prevSlideMessage: 'Opinión anterior',
      nextSlideMessage: 'Siguiente opinión',
    },
  });
</script>

<style is:global>
  #swiper-testimonios .swiper-pagination-bullet {
    background: var(--color-tinta-suave);
  }
  #swiper-testimonios .swiper-pagination-bullet-active {
    background: var(--color-coral);
  }
</style>
