---
import data from '../data/paquetes.json';

const wa = (paquete: string, tipo: string) =>
  'https://wa.me/50375878108?text=' +
  encodeURIComponent(`Hola AlemanArt, me interesa el ${paquete} de ${tipo}. ¿Me pueden dar más información?`);
---

<section id="paquetes" class="scroll-mt-20 bg-white py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center">
      <h2 class="section-title text-3xl sm:text-4xl">Paquetes fotográficos</h2>
      <p class="mx-auto mt-3 max-w-xl text-tinta-suave">
        Nos adaptamos a tus necesidades y a lo que desees para hacer de tu evento una
        experiencia única.
      </p>

      <div
        class="mt-8 inline-flex max-w-full rounded-full border border-tinta/10 bg-crema p-1"
        role="tablist"
        aria-label="Tipo de paquete"
      >
        <button
          type="button"
          class="tab-paquete shrink-0 rounded-full px-4 py-2 text-xs font-medium transition-colors sm:px-6 sm:text-sm"
          data-target="eventos"
          role="tab"
          aria-selected="true"
        >
          Eventos
        </button>
        <button
          type="button"
          class="tab-paquete shrink-0 rounded-full px-4 py-2 text-xs font-medium transition-colors sm:px-6 sm:text-sm"
          data-target="casuales"
          role="tab"
          aria-selected="false"
        >
          Sesiones casuales
        </button>
      </div>
    </div>

    {
      (['eventos', 'casuales'] as const).map((tipo) => (
        <div
          id={`grupo-${tipo}`}
          class:list={['mt-10 grid gap-6 md:grid-cols-3', tipo === 'casuales' && 'hidden']}
          role="tabpanel"
        >
          {data[tipo].map((p) => (
            <article
              class:list={[
                'flex flex-col rounded-2xl border p-6 sm:p-7',
                p.destacado
                  ? 'border-coral bg-crema shadow-lg'
                  : 'border-tinta/10 bg-white',
              ]}
            >
              {p.destacado && (
                <span class="mb-3 self-start rounded-full bg-coral/10 px-3 py-1 text-xs font-semibold text-coral">
                  Más elegido
                </span>
              )}
              <h3 class="section-title text-2xl">{p.nombre}</h3>
              <p class="mt-1 text-3xl font-semibold text-azul">{p.precio}</p>
              <ul class="mt-5 flex-1 space-y-2.5 text-sm leading-relaxed text-tinta-suave">
                {p.items.map((item) => (
                  <li class="flex gap-2.5">
                    <svg
                      class="mt-1 h-3.5 w-3.5 shrink-0 text-dorado"
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M6.5 12.5 2 8l1.4-1.4 3.1 3.1 6.1-6.1L14 5z" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
              {p.nota && (
                <p class="mt-4 flex items-start gap-2 rounded-lg bg-dorado/10 px-3 py-2.5 text-xs font-medium italic leading-relaxed text-coral-oscuro">
                  <svg
                    class="mt-0.5 h-3.5 w-3.5 shrink-0"
                    viewBox="0 0 16 16"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm.75 10.5h-1.5v-4h1.5zm0-5.5h-1.5V4.5h1.5z" />
                  </svg>
                  {p.nota}
                </p>
              )}
              <a
                href={wa(p.nombre, tipo === 'eventos' ? 'eventos' : 'sesiones casuales')}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  'mt-6 rounded-full py-2.5 text-center text-sm font-medium transition-colors',
                  p.destacado
                    ? 'bg-coral text-white hover:bg-coral-oscuro'
                    : 'border border-tinta/15 hover:border-azul hover:text-azul',
                ]}
              >
                Cotizar este paquete
              </a>
            </article>
          ))}
        </div>
      ))
    }

    <div class="mt-14 rounded-2xl bg-crema p-8">
      <h3 class="section-title text-2xl">Extras para tu evento</h3>
      <ul class="mt-5 grid gap-x-8 gap-y-2.5 text-sm text-tinta-suave sm:grid-cols-2">
        {
          data.extras.map((e) => (
            <li class="flex gap-2.5">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul" aria-hidden="true" />
              {e}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-paquete');
  const pintar = () => {
    tabs.forEach((t) => {
      const activo = t.getAttribute('aria-selected') === 'true';
      t.classList.toggle('bg-coral', activo);
      t.classList.toggle('text-white', activo);
      t.classList.toggle('text-tinta-suave', !activo);
    });
  };
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
      document
        .querySelectorAll('[id^="grupo-"]')
        .forEach((g) => g.classList.toggle('hidden', g.id !== `grupo-${tab.dataset.target}`));
      pintar();
    });
  });
  pintar();
</script>
