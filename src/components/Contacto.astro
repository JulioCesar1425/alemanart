---
import { Image } from 'astro:assets';
import logo from '../assets/marca/logo.png';

const WHATSAPP_URL =
  'https://wa.me/50375878108?text=' +
  encodeURIComponent('Hola AlemanArt, me gustaría más información sobre sus servicios.');
---

<section id="contacto" class="reveal scroll-mt-20 bg-tinta py-16 text-crema md:py-24">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <Image src={logo} alt="AlemanArt Photography" class="mx-auto h-9 w-auto sm:h-10" widths={[300, 600]} sizes="260px" />
    <h2 class="section-title mt-8 text-3xl sm:text-4xl">Hagamos de tu evento un recuerdo eterno</h2>
    <p class="mx-auto mt-4 max-w-xl text-crema/70">
      Escríbenos y solicita tu cotización personalizada. Nos adaptamos a tus necesidades.
    </p>

    <a
      href={WHATSAPP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex max-w-full flex-wrap items-center justify-center gap-x-2 rounded-full bg-coral px-6 py-3.5 text-sm font-medium text-white transition-colors hover:bg-coral-oscuro sm:px-8 sm:text-base"
    >
      <span>Escribir por WhatsApp</span>
      <span aria-hidden="true" class="hidden sm:inline">·</span>
      <span class="whitespace-nowrap">7587-8108</span>
    </a>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
      <a
        href="https://www.facebook.com/share/1JTTC3ev6P/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 text-sm text-crema/80 transition-colors hover:text-white"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z"
          ></path>
        </svg>
        Aleman Art SV
      </a>
      <a
        href="https://www.instagram.com/alemanart_sv"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 text-sm text-crema/80 transition-colors hover:text-white"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2-.1-1.3-.1-1.7-.1-4.9s0-3.6.1-4.9c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4 1.3-.1 1.7-.1 4.9-.1zm0 1.8c-3.1 0-3.5 0-4.8.1-1.1.1-1.5.2-1.9.4-.5.2-.8.4-1.1.7-.3.3-.6.7-.7 1.1-.1.3-.3.8-.4 1.9-.1 1.2-.1 1.6-.1 4.8s0 3.5.1 4.8c.1 1.1.2 1.5.4 1.9.2.5.4.8.7 1.1.3.3.7.6 1.1.7.3.1.8.3 1.9.4 1.2.1 1.6.1 4.8.1s3.5 0 4.8-.1c1.1-.1 1.5-.2 1.9-.4.5-.2.8-.4 1.1-.7.3-.3.6-.7.7-1.1.1-.3.3-.8.4-1.9.1-1.2.1-1.6.1-4.8s0-3.5-.1-4.8c-.1-1.1-.2-1.5-.4-1.9-.2-.5-.4-.8-.7-1.1-.3-.3-.7-.6-1.1-.7-.3-.1-.8-.3-1.9-.4-1.2-.1-1.6-.1-4.8-.1zm0 3.1a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 8.2a3.2 3.2 0 1 0 0-6.5 3.2 3.2 0 0 0 0 6.5zm6.3-8.4a1.2 1.2 0 1 1-2.3 0 1.2 1.2 0 0 1 2.3 0z"
          ></path>
        </svg>
        alemanart_sv
      </a>
    </div>
  </div>
</section>

<footer class="bg-tinta py-6 text-center text-sm text-crema/50">
  <div class="brand-bar mb-6"></div>
  © {new Date().getFullYear()} AlemanArt · Fotografía y video · El Salvador
</footer>
