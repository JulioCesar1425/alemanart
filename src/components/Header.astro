---
import { Image } from 'astro:assets';
import logo from '../assets/marca/logo.png';

const enlaces = [
  { href: '#quien-soy', texto: 'Quién soy' },
  { href: '#galeria', texto: 'Galería' },
  { href: '#opiniones', texto: 'Opiniones' },
  { href: '#paquetes', texto: 'Paquetes' },
  { href: '#video', texto: 'Video' },
  { href: '#contacto', texto: 'Contacto' },
];
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-tinta/5 bg-crema/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="#inicio" class="flex items-center rounded-full bg-tinta px-4 py-1.5">
      <Image src={logo} alt="AlemanArt Photography" class="h-6 w-auto sm:h-7" widths={[240, 480]} sizes="200px" />
    </a>

    <nav class="hidden items-center gap-4 md:flex lg:gap-7" aria-label="Navegación principal">
      {
        enlaces.map((e) => (
          <a
            href={e.href}
            class="whitespace-nowrap text-sm font-medium text-tinta-suave transition-colors hover:text-coral"
          >
            {e.texto}
          </a>
        ))
      }
    </nav>

    <button
      id="menu-btn"
      class="flex h-10 w-10 items-center justify-center rounded-md text-tinta md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="menu-movil"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>
  </div>

  <nav
    id="menu-movil"
    class="hidden border-t border-tinta/5 bg-crema px-4 pb-4 md:hidden"
    aria-label="Navegación móvil"
  >
    {
      enlaces.map((e) => (
        <a href={e.href} class="block py-3 text-sm font-medium text-tinta-suave">
          {e.texto}
        </a>
      ))
    }
  </nav>
  <div class="brand-bar"></div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu-movil');
  btn?.addEventListener('click', () => {
    const abierto = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(abierto));
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
